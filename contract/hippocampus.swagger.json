          {
            "name": "body",
            "description": "SearchMemoriesRequest queries the optional secondary content-search index (opensearch.enabled)\nfor memories whose body matches the query. Results are always re-read from the primary store,\nwhich remains authoritative; ids the index returns that the primary store no longer holds are\nsilently dropped. When reinforce is true the matched memories are recalled - resetting their\ndecay clocks and raising their effective significance - rather than merely fetched.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/protoSearchMemoriesRequest"
            }
          }
        ],
        "tags": [
          "Hippocampus"
        ]
      }
    },
    "/v1/memories/{id}": {
      "patch": {
        "summary": "UpdateMemory applies a partial update to an existing memory: only the fields carrying a value\n(significance, body, event_id, group, time_stamp) overwrite the stored row. is_binary and\nis_summary are NOT updatable here - they are set at creation and by ReplaceMemoriesWithSummary\n- so any updated content must stay consistent with the memory's existing is_binary/is_summary:\na non-binary memory is re-indexed for content search, so its new body must remain valid text,\nand a summary memory should keep summary-appropriate content. An unknown id returns NotFound\n(no memory is created).",
        "operationId": "Hippocampus_UpdateMemory",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/protoGeneralResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/HippocampusUpdateMemoryBody"
            }
          }
        ],
        "tags": [
          "Hippocampus"
        ]
      }
