    "protoSearchMemoriesRequest": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "limit": {
          "type": "integer",
          "format": "int32",
          "title": "maximum results; a value \u003c= 0 selects the default (10)"
        },
        "eventId": {
          "type": "string",
          "title": "optional: restrict matches to a single event"
        },
        "reinforce": {
          "type": "boolean",
          "title": "route matches through recall, reinforcing them"
        },
        "group": {
          "type": "string",
          "title": "optional: restrict matches to memories carrying this group label"
        }
      },
      "description": "SearchMemoriesRequest queries the optional secondary content-search index (opensearch.enabled)\nfor memories whose body matches the query. Results are always re-read from the primary store,\nwhich remains authoritative; ids the index returns that the primary store no longer holds are\nsilently dropped. When reinforce is true the matched memories are recalled - resetting their\ndecay clocks and raising their effective significance - rather than merely fetched."
    },
    "protoSignificancePlacement": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/definitions/SignificancePlacementMode"
        },
        "anchor": {
          "type": "integer",
          "format": "int32",
          "title": "anchor significance value; ignored when anchor_id is set"
        },
        "anchorId": {
          "type": "string",
          "title": "anchor by an existing item's id, whose significance is looked up"
        },
        "upper": {
          "type": "integer",
          "format": "int32",
          "title": "BETWEEN only: the upper bound significance; ignored when upper_id is set"
        },
        "upperId": {
          "type": "string",
          "title": "BETWEEN only: the upper bound by an existing item's id"
        }
      },
      "description": "SignificancePlacement positions an item's significance relative to existing values instead of\ntaking the absolute `significance` field. It exists because significance is a dense integer with\nno room between adjacent values: this lets a client say \"just above the 5s\" or \"between 5 and 6\"\nand have the server open a gap for it. Write-only on StoreEvent/StoreMemory/UpdateMemory and\nUpdateEventSignificance; it is never populated on read responses. When mode is UNSPECIFIED the\nabsolute `significance` value is used as-is (0 meaning unranked)."
    },
    "protoStoreEventResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "title": "the stored event's id; empty when the event was not retained"
        },
        "memoryCount": {
          "type": "integer",
          "format": "int32",
          "title": "nested memories stored (those below memory.minimumSignificance are dropped)"
        },
        "rejected": {
          "type": "boolean",
          "title": "true when the event was dropped for significance below event.minimumSignificance"
        }
      },
      "description": "StoreEventResponse carries the stored event's id and how many of its nested memories were\nretained. An event whose significance is below event.minimumSignificance is quietly forgotten,\nlike a brain that simply does not retain the insignificant: no error is returned, id is empty,\nmemory_count is 0 (its nested memories are not stored either), and rejected is true."
    },
    "protoStoreMemoryResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "title": "the stored memory's id; empty when the memory was not retained"
        },
        "rejected": {
          "type": "boolean",
          "title": "true when the memory was dropped for significance below memory.minimumSignificance"
        }
      },
      "description": "StoreMemoryResponse carries the stored memory's id. A memory whose significance is below\nmemory.minimumSignificance is quietly forgotten, like a brain that simply does not retain the\ninsignificant: no error is returned, id is empty, and rejected is true."
    },
    "protoSummarizationCandidate": {
      "type": "object",
      "properties": {
        "eventId": {
          "type": "string"
        },
        "eventName": {
          "type": "string"
        },
        "memoryCount": {
          "type": "integer",
          "format": "int32"
        }
      },
      "description": "SummarizationCandidate identifies an event whose memories have accumulated enough, and gone\nquiet for long enough, to be worth condensing into a single summary memory via\nReplaceMemoriesWithSummary."
    },
    "protoTransferRequest": {
      "type": "object",
      "properties": {
        "clear": {
          "type": "boolean"
        }
