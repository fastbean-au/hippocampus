  "definitions": {
    "HippocampusEndEventBody": {
      "type": "object",
      "properties": {
        "timeEnd": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "HippocampusUpdateEventSignificanceBody": {
      "type": "object",
      "properties": {
        "significance": {
          "type": "integer",
          "format": "int32"
        },
        "placement": {
          "$ref": "#/definitions/protoSignificancePlacement",
          "title": "write-only: rank relative to existing values (see SignificancePlacement)"
        }
      }
    },
    "HippocampusUpdateMemoryBody": {
      "type": "object",
      "properties": {
        "timeStamp": {
          "type": "string",
          "format": "int64",
          "title": "UnixNano; defaults to the current time when unset (0) on create"
        },
        "significance": {
          "type": "integer",
          "format": "int32"
        },
        "eventId": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "isBinary": {
          "$ref": "#/definitions/protoBool"
        },
        "timeRecalled": {
          "type": "string",
          "format": "int64"
        },
        "recallCount": {
          "type": "integer",
          "format": "int32"
        },
        "isSummary": {
          "type": "boolean"
        },
        "group": {
          "type": "string",
          "title": "optional freeform grouping/context label (system, subsystem, owner, ...)"
        },
        "placement": {
          "$ref": "#/definitions/protoSignificancePlacement",
          "title": "write-only: rank relative to existing values (see SignificancePlacement)"
        }
      }
    },
    "SignificancePlacementMode": {
      "type": "string",
      "enum": [
        "UNSPECIFIED",
        "ABOVE",
        "BELOW",
        "BETWEEN"
      ],
      "default": "UNSPECIFIED",
      "title": "- UNSPECIFIED: ignore placement; use the absolute significance value\n - ABOVE: rank just above the anchor, below the next-higher value\n - BELOW: rank just below the anchor, above the next-lower value\n - BETWEEN: rank strictly between the anchor (lower) and upper bounds"
    },
    "protoBool": {
      "type": "string",
      "enum": [
        "UNSPECIFIED",
        "FALSE",
        "TRUE"
      ],
      "default": "UNSPECIFIED"
    },
    "protoClearRequest": {
      "type": "object",
      "properties": {
        "manifestId": {
          "type": "string"
        }
      },
      "description": "Clear deletes exactly the records captured by the Export/Transfer run that produced the\nmanifest: memories are deleted only if neither created nor recalled since the snapshot, and\nevents only once they have no memories left. Manifests are held in memory - a restart discards\nthem."
    },
    "protoClearResponse": {
      "type": "object",
      "properties": {
        "memoriesCleared": {
          "type": "integer",
          "format": "int32"
        },
        "eventsCleared": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "protoDeleteMemoriesRequest": {
      "type": "object",
      "properties": {
