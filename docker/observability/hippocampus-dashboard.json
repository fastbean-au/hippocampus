{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "title": "Hippocampus",
  "uid": "hippocampus-overview",
  "tags": ["hippocampus"],
  "schemaVersion": 39,
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Ingest",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Store rate (memories & events)",
      "description": "Accepted writes per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_memories_stored_total[$__rate_interval]))", "legendFormat": "memories" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_events_stored_total[$__rate_interval]))", "legendFormat": "events" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_memories_recalled_total[$__rate_interval]))", "legendFormat": "recalls" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory body size",
      "description": "Distribution of stored memory-body sizes (histogram quantiles).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(hippocampus_memory_body_bytes_bucket[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(hippocampus_memory_body_bytes_bucket[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(hippocampus_memory_body_bytes_bucket[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingest throughput",
      "description": "Bytes of memory body accepted per second (histogram sum rate).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_memory_body_bytes_sum[$__rate_interval]))", "legendFormat": "bytes/s" }
      ]
    },
    {
      "type": "row",
      "title": "Forgetting (reaping)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Consolidated rate",
      "description": "Memories and events forgotten by the sleep cycle, per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_memories_consolidated_total[$__rate_interval]))", "legendFormat": "memories" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_events_consolidated_total[$__rate_interval]))", "legendFormat": "events" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Eviction rate & bytes reclaimed",
      "description": "Capacity-driven eviction: rows evicted per second and estimated bytes reclaimed per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [ { "matcher": { "id": "byName", "options": "bytes/s" }, "properties": [ { "id": "unit", "value": "Bps" }, { "id": "custom.axisPlacement", "value": "right" } ] } ] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_memories_evicted_total[$__rate_interval]))", "legendFormat": "memories" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_events_evicted_total[$__rate_interval]))", "legendFormat": "events" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hippocampus_bytes_evicted_total[$__rate_interval]))", "legendFormat": "bytes/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rejected rate by reason",
      "description": "Writes rejected at storage time, split by reason.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (reason) (rate(hippocampus_memories_rejected_total[$__rate_interval]))", "legendFormat": "memory: {{reason}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (reason) (rate(hippocampus_events_rejected_total[$__rate_interval]))", "legendFormat": "event: {{reason}}" }
      ]
    },
    {
      "type": "row",
      "title": "Capacity & store state",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "Used bytes",
      "description": "Live bytes the store occupies, sampled each sleep cycle when a byte capacity is set.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hippocampus_used_bytes)", "legendFormat": "used_bytes" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Capacity pressure",
      "description": "Deletion-threshold multiplier derived from store utilisation; > 1 means forgetting is intensifying as the store fills.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hippocampus_capacity_pressure)", "legendFormat": "pressure" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Store size (row counts)",
      "description": "Current events and memories held, memories split by whether they belong to an event.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(hippocampus_events_count)", "legendFormat": "events" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(hippocampus_memories_count)", "legendFormat": "memories" }
      ]
    },
    {
      "type": "row",
      "title": "Sleep cycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "type": "timeseries",
      "title": "Sleep cycle duration",
      "description": "Wall-clock duration of a full consolidate + evict + preserve cycle (histogram quantiles). A p95 climbing toward sleep.periodSeconds is a warning sign.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(hippocampus_sleep_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(hippocampus_sleep_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(hippocampus_sleep_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sleep cycles by outcome",
      "description": "Sleep cycles per second, split by success. Any sustained success=false is trouble.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (success) (rate(hippocampus_sleeps_total[$__rate_interval]))", "legendFormat": "success={{success}}" }
      ]
    }
  ]
}
